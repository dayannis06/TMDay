          "Type": "Functional"
        },
        {
          "Id": 10,
          "TcId": 3,
          "Name": "Payment with insufficient funds",
          "PreRequisites": "Card with insufficient balance",
          "Data": "cardNumber: 4532015112830366, balance: $10.00, amount: $99.99",
          "Steps": "1. Proceed to checkout\n2. Enter card with low balance\n3. Click pay button",
          "ExpectedResult": "Payment declined with error message: \u0027Insufficient funds\u0027",
          "ActualResult": "Payment declined with error message: \u0027Insufficient funds\u0027",
          "Status": "Failed",
          "Type": "Functional"
        }
      ]
