          "Name": "Successful payment with credit card",
          "PreRequisites": "Valid credit card in system, Payment gateway is active",
          "Data": "cardNumber: 4532015112830366, expiry: 12/25, cvv: 123, amount: $99.99",
          "Steps": "1. Proceed to checkout\n2. Select credit card payment\n3. Enter card details\n4. Click pay button",
          "ExpectedResult": "Payment processed successfully and order confirmation is displayed",
          "ActualResult": "Payment processed successfully and order confirmation is displayed",
          "Status": "Approved",
          "Type": "Functional"
        },
        {
          "Id": 9,
          "TcId": 3,
          "Name": "Payment with expired card",
          "PreRequisites": "Expired credit card number available",
          "Data": "cardNumber: 4532015112830366, expiry: 01/20, cvv: 123, amount: $99.99",
          "Steps": "1. Proceed to checkout\n2. Select credit card payment\n3. Enter expired card details\n4. Click pay button",
          "ExpectedResult": "Payment declined with error message: \u0027Card has expired\u0027",
          "ActualResult": "Payment declined with error message: \u0027Card has expired\u0027",
