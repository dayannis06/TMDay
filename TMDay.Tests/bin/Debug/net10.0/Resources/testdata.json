    {
      "TcId": 1,
      "TcName": "User Authentication Login",
      "TcEpic": "Authentication System",
      "TcApp": "TMDay.API",
      "TcComponent": "Authentication",
      "TcStory": "As a user, I want to login with my credentials",
      "TcAssigned": "John Lenon",
      "CreatedAt": "2026-03-31T00:00:00Z",
      "UpdatedAt": null,
      "TestScenarios": [
        {
          "Id": 1,
          "TcId": 1,
          "Name": "Successful login with valid credentials",
          "PreRequisites": "User account exists in the system",
          "Data": "username: admin@example.com, password: SecurePass123",
          "Steps": "1. Navigate to login page\n2. Enter valid email\n3. Enter valid password\n4. Click login button",
          "ExpectedResult": "User successfully authenticated and redirected to dashboard",
          "ActualResult": "User is authenticated and redirected to dashboard",
          "Status": "Approved",
          "Type": "Functional"
        },
        {
          "Id": 2,
          "TcId": 1,
          "Name": "Login with invalid password",
          "PreRequisites": "User account exists in the system",
          "Data": "username: admin@example.com, password: WrongPassword123",
          "Steps": "1. Navigate to login page\n2. Enter valid email\n3. Enter invalid password\n4. Click login button",
          "ExpectedResult": "Error message displayed: \u0027Invalid credentials\u0027",
          "ActualResult": "Error message displayed: \u0027Invalid credentials\u0027",
          "Status": "Failed",
          "Type": "Functional"
        },
        {
          "Id": 3,
          "TcId": 1,
          "Name": "Login with non-existent email",
          "PreRequisites": "Database connection is active",
          "Data": "username: nonexistent@example.com, password: AnyPassword123",
          "Steps": "1. Navigate to login page\n2. Enter non-existent email\n3. Enter any password\n4. Click login button",
          "ExpectedResult": "Error message displayed: \u0027User not found\u0027",
          "ActualResult": "Error message displayed: \u0027User not found\u0027",
          "Status": "Failed",
          "Type": "Functional"
        }
      ]
    },
    {
      "TcId": 2,
      "TcName": "Product Search Functionality",
      "TcEpic": "E-commerce Features",
      "TcApp": "TMDay.API",
      "TcComponent": "Search Engine",
      "TcStory": "As a customer, I want to search for products by name and category",
      "TcAssigned": "Jane Smith",
      "CreatedAt": "2026-03-31T00:00:00Z",
      "UpdatedAt": null,
      "TestScenarios": [
        {
          "Id": 4,
          "TcId": 2,
          "Name": "Search product by exact name",
          "PreRequisites": "Database contains products with sample data",
          "Data": "searchQuery: \u0027Laptop\u0027",
          "Steps": "1. Open search bar\n2. Enter \u0027Laptop\u0027\n3. Press enter or click search",
          "ExpectedResult": "All products with \u0027Laptop\u0027 in the name are displayed",
          "ActualResult": "All products with \u0027Laptop\u0027 in the name are displayed",
          "Status": "Approved",
          "Type": "Functional"
        },
        {
          "Id": 5,
          "TcId": 2,
          "Name": "Search with empty query",
          "PreRequisites": "Search functionality is loaded",
          "Data": "searchQuery: \u0027\u0027",
          "Steps": "1. Open search bar\n2. Leave search field empty\n3. Click search button",
          "ExpectedResult": "Either show all products or display validation message",
          "ActualResult": "Validation message displayed: \u0027Please enter a search term\u0027",
          "Status": "Blocked",
          "Type": "Functional"
        },
        {
          "Id": 6,
          "TcId": 2,
          "Name": "Search with special characters",
          "PreRequisites": "Database connection is active",
          "Data": "searchQuery: \u0027@#$%^\u0026*()\u0027",
          "Steps": "1. Open search bar\n2. Enter special characters\n3. Click search button",
          "ExpectedResult": "No results found or error message is displayed",
          "ActualResult": "No results found message displayed",
          "Status": "Failed",
          "Type": "Functional"
        },
        {
          "Id": 7,
          "TcId": 2,
          "Name": "Search with partial name",
          "PreRequisites": "Products exist with similar names",
          "Data": "searchQuery: \u0027Lap\u0027",
          "Steps": "1. Open search bar\n2. Enter \u0027Lap\u0027\n3. Click search button",
          "ExpectedResult": "All products containing \u0027Lap\u0027 in the name are displayed",
          "ActualResult": "All products containing \u0027Lap\u0027 in the name are displayed",
          "Status": "Approved",
          "Type": "Functional"
        }
      ]
    },
